#!/usr/bin/env bash
# scan-batch — continuous duplex scan loop for mixed-document batches.
#
# Scans until the ADF empties, then watches the scanner's page-loaded sensor
# and resumes the moment more paper lands. Pages accumulate as per-page JPEGs
# in a staging dir for the batch workflow (Claude analysis -> batch-file).
# Works with the Brother ADS-4300N (via escl-scan) and the borrowed ScanSnap
# iX500 (via SANE/scanimage); auto-detects whichever is connected.
#
# Part of the scan-it project (~/Arik/dev/office/scan-it).
set -euo pipefail

scanimage_bin="${SCAN_BATCH_SCANIMAGE:-scanimage}"
poll_secs="${SCAN_BATCH_POLL_SECS:-2}"
[[ "$poll_secs" =~ ^[0-9]+$ ]] && (( poll_secs >= 1 )) || poll_secs=2

usage() {
  cat <<'EOF'
Usage: scan-batch [options]

Continuous batch scan from the ADF. Feed paper in any number of chunks;
scanning resumes automatically when the paper sensor sees a new stack.

End the batch by pressing Enter, or after --idle seconds with no paper.
Ctrl-C preserves the staging dir (continue later with --resume).

Options:
  --idle N             end the batch after N seconds with no paper (default: 60)
  -s, --simplex        front side only (default: duplex)
  -g, --gray           grayscale (default: color)
  -r, --resolution N   dpi (default: 300)
  -o, --outdir DIR     parent dir for batch staging dirs
                       (default: ~/Documents/Scans/.batches)
  --resume DIR         continue an interrupted batch staging dir
      --scanner WHICH  brother | ix500 | auto (default: auto — Brother first;
                       env SCAN_SCANNER sets the default)
  -x, --scanopt ARG    iX500 only: extra option passed through to scanimage
                       (repeatable)
  -h, --help           show this help

Exit codes:
  0 success (>=1 page)        1 no scanner / device lost / jam
  2 no pages scanned          64 usage error
  66 bad --resume dir         130 interrupted (Ctrl-C)
EOF
}

source_opt="ADF Duplex"
mode="Color"
resolution=300
idle=60
outparent="$HOME/Documents/Scans/.batches"
resume_dir=""
scanner="${SCAN_SCANNER:-auto}"
scanopts=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --idle)
      [[ $# -ge 2 ]] || { echo "scan-batch: $1 requires a value" >&2; exit 64; }
      [[ "$2" =~ ^[0-9]+$ ]] || { echo "scan-batch: $1 requires an integer value" >&2; exit 64; }
      idle="$2"; shift ;;
    -s|--simplex) source_opt="ADF Front" ;;
    -g|--gray) mode="Gray" ;;
    -r|--resolution)
      [[ $# -ge 2 ]] || { echo "scan-batch: $1 requires a value" >&2; exit 64; }
      [[ "$2" =~ ^[0-9]+$ ]] || { echo "scan-batch: $1 requires an integer value" >&2; exit 64; }
      resolution="$2"; shift ;;
    -o|--outdir)
      [[ $# -ge 2 ]] || { echo "scan-batch: $1 requires a value" >&2; exit 64; }
      outparent="$2"; shift ;;
    --resume)
      [[ $# -ge 2 ]] || { echo "scan-batch: $1 requires a value" >&2; exit 64; }
      resume_dir="$2"; shift ;;
    --scanner)
      [[ $# -ge 2 ]] || { echo "scan-batch: $1 requires a value" >&2; exit 64; }
      scanner="$2"; shift ;;
    -x|--scanopt)
      [[ $# -ge 2 ]] || { echo "scan-batch: $1 requires a value" >&2; exit 64; }
      scanopts+=("$2"); shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "scan-batch: unknown argument: $1" >&2; usage >&2; exit 64 ;;
  esac
  shift
done

command -v jq >/dev/null 2>&1 || { echo "scan-batch: jq not found" >&2; exit 1; }

case "$scanner" in
  auto|brother|ix500) ;;
  *) echo "scan-batch: --scanner must be auto, brother, or ix500" >&2; exit 64 ;;
esac

script_dir=$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)
escl_bin="${SCAN_BATCH_ESCL:-$script_dir/escl-scan}"

device_kind=""
device=""

discover_fujitsu() {
  "$scanimage_bin" -L 2>/dev/null | grep -i fujitsu | head -1 \
    | sed -e 's/^device `//' -e "s/' is a.*//" || true
}

# Sets device_kind + device to whatever is connected, honoring --scanner.
discover_scanner() {
  if [[ "$scanner" != "ix500" && -x "$escl_bin" ]]; then
    if device=$("$escl_bin" --discover 2>/dev/null); then
      device_kind="escl"
      return 0
    fi
  fi
  if [[ "$scanner" != "brother" ]] && command -v "$scanimage_bin" >/dev/null 2>&1; then
    device=$(discover_fujitsu)
    if [[ -n "$device" ]]; then
      device_kind="fujitsu"
      return 0
    fi
  fi
  device_kind=""
  device=""
  return 1
}

if ! discover_scanner; then
  echo "scan-batch: no scanner found (looked for: $scanner)." >&2
  echo "  Brother: check power/USB and that the Push Scan Tool services run." >&2
  echo "  iX500: check the lid is open (that powers it on) and USB is connected." >&2
  echo "  Run scan-diag for a full checkup." >&2
  exit 1
fi

if [[ "$device_kind" == "escl" && -n "${scanopts[*]:-}" ]]; then
  echo "scan-batch: -x/--scanopt passes scanimage options and is iX500-only." >&2
  exit 64
fi

if [[ -n "$resume_dir" ]]; then
  staging="${resume_dir%/}"
  [[ -d "$staging/pages" ]] || { echo "scan-batch: not a batch staging dir: $resume_dir" >&2; exit 66; }
  batch_id=$(basename "$staging")
  started=$(jq -r '.started // empty' "$staging/batch.json" 2>/dev/null || true)
else
  batch_id="batch-$(date +%Y%m%d-%H%M%S)"
  staging="$outparent/$batch_id"
  mkdir -p "$staging/pages"
  started=""
fi
[[ -n "$started" ]] || started=$(date +%Y-%m-%dT%H:%M:%S%z)

page_count() { find "$staging/pages" -name 'page-*.jpg' | wc -l | tr -d ' '; }

# chunks in batch.json records this run only — a resumed batch does not
# re-derive earlier chunk boundaries.
chunk_counts=""   # space-separated page count per chunk this run

write_batch_json() {
  local arr="[]"
  [[ -z "$chunk_counts" ]] || arr="[${chunk_counts// /,}]"
  jq -n --arg id "$batch_id" --arg started "$started" \
        --arg updated "$(date +%Y-%m-%dT%H:%M:%S%z)" \
        --arg source "$source_opt" --arg mode "$mode" \
        --argjson resolution "$resolution" \
        --argjson pages "$(page_count)" --argjson chunks "$arr" \
    '{batch: $id, started: $started, updated: $updated, source: $source,
      mode: $mode, resolution: $resolution, pages: $pages, chunks: $chunks}' \
    > "$staging/batch.json"
}

page_loaded() {
  if [[ "$device_kind" == "escl" ]]; then
    "$escl_bin" --page-loaded >/dev/null 2>&1
  else
    "$scanimage_bin" -d "$device" -A 2>/dev/null \
      | grep -- '--page-loaded' | grep -q '\[yes\]'
  fi
}

# The iX500 has documented USB flakiness: if it drops off the bus, retry
# discovery with backoff, then bail preserving the staging dir.
ensure_device() {
  local tries=0
  while :; do
    if discover_scanner; then return 0; fi
    tries=$((tries + 1))
    if (( tries >= 3 )); then
      write_batch_json
      echo "scan-batch: scanner disappeared mid-batch (USB?). Staging preserved." >&2
      echo "  Resume with: scan-batch --resume $staging" >&2
      exit 1
    fi
    sleep $(( tries * 2 ))
  done
}

scan_chunk() {
  local start=$(( $(page_count) + 1 ))
  if [[ "$device_kind" == "escl" ]]; then
    local escl_args=(-r "$resolution" -o "$staging/pages" --start "$start")
    [[ "$source_opt" == "ADF Front" ]] && escl_args+=(-s)
    [[ "$mode" == "Gray" ]] && escl_args+=(-g)
    # Exit 2 (feeder emptied between the sensor poll and the scan) is normal
    # here; the caller's page-count delta is the real success signal.
    set +e
    "$escl_bin" "${escl_args[@]}"
    set -e
    return 0
  fi
  # In --batch mode scanimage always ends with "Document feeder out of
  # documents" and nonzero status — the normal terminator, not an error.
  set +e
  "$scanimage_bin" -d "$device" --source "$source_opt" --mode "$mode" \
    --resolution "$resolution" --format=jpeg \
    --ald=yes --swdeskew=yes \
    ${scanopts[@]+"${scanopts[@]}"} \
    --batch="$staging/pages/page-%03d.jpg" --batch-start="$start" --progress
  set -e
}

on_interrupt() {
  write_batch_json
  echo ""
  echo "scan-batch: interrupted — staging preserved: $staging"
  echo "  Resume with: scan-batch --resume $staging"
  exit 130
}
trap on_interrupt INT

finish() {
  local total
  total=$(page_count)
  write_batch_json
  if (( total == 0 )); then
    [[ -n "$resume_dir" ]] || rm -rf "$staging"
    echo "scan-batch: no pages scanned — nothing staged." >&2
    exit 2
  fi
  if [[ "$source_opt" == "ADF Duplex" ]] && (( total % 2 != 0 )); then
    echo "scan-batch: WARNING — odd page count ($total) from a duplex batch;" >&2
    echo "  a multifeed (two sheets stuck together) is likely. Verify the pages." >&2
  fi
  echo "Batch complete: $total page(s)."
  echo "$staging"
  exit 0
}

# Block until paper lands (return 0) or the batch ends (Enter / idle timeout,
# which calls finish and never returns).
wait_for_paper() {
  local waited=0
  while (( waited < idle )); do
    if [[ -t 0 ]]; then
      # read doubles as the poll sleep and the Enter-to-end check.
      if read -r -s -t "$poll_secs"; then finish; fi
    else
      sleep "$poll_secs"
    fi
    waited=$(( waited + poll_secs ))
    if page_loaded; then return 0; fi
    ensure_device
  done
  finish
}

echo "Batch $batch_id ($source_opt, $mode, ${resolution}dpi)"
echo "Feed the ADF. Enter ends the batch; idle timeout ${idle}s."

zero_scans=0   # consecutive scans where the sensor saw paper but 0 pages fed

while :; do
  if page_loaded; then
    before=$(page_count)
    scan_chunk
    after=$(page_count)
    if (( after > before )); then
      zero_scans=0
      chunk_counts="${chunk_counts:+$chunk_counts }$((after - before))"
      echo "Chunk done: $((after - before)) page(s) — total $after."
      write_batch_json
    else
      # sensor said paper but the scan produced nothing — jam/misfeed,
      # or device trouble
      zero_scans=$(( zero_scans + 1 ))
      if (( zero_scans >= 3 )); then
        write_batch_json
        echo "scan-batch: paper detected but nothing feeding (jam or misfeed?). Staging preserved." >&2
        echo "  Re-seat the stack, then resume with: scan-batch --resume $staging" >&2
        exit 1
      fi
      ensure_device
      sleep "$poll_secs"
    fi
  else
    wait_for_paper
  fi
done
