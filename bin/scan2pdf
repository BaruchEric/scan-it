#!/usr/bin/env bash
# scan2pdf — scan a stack from the ADF to a dated, multi-page PDF.
#
# Supports the Brother ADS-4300N (via escl-scan) and the borrowed ScanSnap
# iX500 (via SANE/scanimage); auto-detects whichever is connected.
#
# Part of the scan-it project (~/Arik/dev/office/scan-it).
# Troubleshooting: run scan-diag, or see TROUBLESHOOTING.md in the project repo.
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: scan2pdf [options] [output-name]

Drop a stack in the ADF, run this, get a dated PDF in ~/Documents/Scans.

Options:
  -s, --simplex        front side only (default: duplex)
  -g, --gray           grayscale (default: color)
  -r, --resolution N   dpi (default: 300)
  -o, --outdir DIR     output directory (default: ~/Documents/Scans)
      --scanner WHICH  brother | ix500 | auto (default: auto — Brother first;
                       env SCAN_SCANNER sets the default)
  -p, --png            iX500 only: lossless PNG intermediates — PDFs ~20x bigger
  -k, --keep-pages     keep intermediate page images next to the PDF (default: delete)
  -x, --scanopt ARG    iX500 only: pass an extra option through to scanimage
                       (repeatable), e.g. -x --ald=yes -x --swdeskew=yes
      --open           open the finished PDF in Preview
  -h, --help           show this help

Exit codes:
  0 success   1 no scanner found   2 empty ADF / no pages   3 PDF assembly failure
EOF
}

source_opt="ADF Duplex"
mode="Color"
resolution=300
outdir="$HOME/Documents/Scans"
img_format="jpeg"
img_ext="jpg"
keep_pages=0
open_pdf=0
name="scan"
scanner="${SCAN_SCANNER:-auto}"
scanopts=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -s|--simplex) source_opt="ADF Front" ;;
    -g|--gray) mode="Gray" ;;
    -r|--resolution)
      [[ $# -ge 2 ]] || { echo "scan2pdf: $1 requires a value" >&2; exit 64; }
      resolution="$2"; shift ;;
    -o|--outdir)
      [[ $# -ge 2 ]] || { echo "scan2pdf: $1 requires a value" >&2; exit 64; }
      outdir="$2"; shift ;;
    -p|--png) img_format="png"; img_ext="png" ;;
    -k|--keep-pages) keep_pages=1 ;;
    -x|--scanopt)
      [[ $# -ge 2 ]] || { echo "scan2pdf: $1 requires a value" >&2; exit 64; }
      scanopts+=("$2"); shift ;;
    --scanner)
      [[ $# -ge 2 ]] || { echo "scan2pdf: $1 requires a value" >&2; exit 64; }
      scanner="$2"; shift ;;
    --open) open_pdf=1 ;;
    -h|--help) usage; exit 0 ;;
    -*) echo "scan2pdf: unknown option: $1" >&2; usage >&2; exit 64 ;;
    *) name="$1" ;;
  esac
  shift
done

case "$scanner" in
  auto|brother|ix500) ;;
  *) echo "scan2pdf: --scanner must be auto, brother, or ix500" >&2; exit 64 ;;
esac

if ! command -v img2pdf >/dev/null 2>&1; then
  echo "scan2pdf: 'img2pdf' not found — install with: brew install img2pdf" >&2
  exit 1
fi

script_dir=$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)
escl_scan="$script_dir/escl-scan"

device_kind=""
device=""
if [[ "$scanner" != "ix500" && -x "$escl_scan" ]]; then
  if device=$("$escl_scan" --discover 2>/dev/null); then
    device_kind="escl"
  fi
fi
if [[ -z "$device_kind" && "$scanner" != "brother" ]] \
   && command -v scanimage >/dev/null 2>&1; then
  # scanimage -L prints:
  #   device `fujitsu:ScanSnap iX500:NNNN' is a FUJITSU ScanSnap iX500 scanner
  device=$(scanimage -L 2>/dev/null | grep -i fujitsu | head -1 \
    | sed -e 's/^device `//' -e "s/' is a.*//" || true)
  [[ -n "$device" ]] && device_kind="fujitsu"
fi
if [[ -z "$device_kind" ]]; then
  echo "scan2pdf: no scanner found (looked for: $scanner)." >&2
  echo "  Brother: check power/USB and that the Push Scan Tool services run." >&2
  echo "  iX500: check the lid is open (that powers it on) and USB is connected." >&2
  echo "  Run scan-diag for a full checkup." >&2
  exit 1
fi

if [[ "$device_kind" == "escl" ]]; then
  if [[ "$img_format" != "jpeg" ]]; then
    echo "scan2pdf: -p/--png is iX500-only (the Brother outputs JPEG);" >&2
    echo "  rerun without -p, or with --scanner ix500." >&2
    exit 64
  fi
  if [[ -n "${scanopts[*]:-}" ]]; then
    echo "scan2pdf: -x/--scanopt passes scanimage options and is iX500-only." >&2
    exit 64
  fi
fi

tmpdir=$(mktemp -d -t scan2pdf)
trap 'rm -rf "$tmpdir"' EXIT

echo "Scanning from '$device' ($source_opt, $mode, ${resolution}dpi)..."
if [[ "$device_kind" == "escl" ]]; then
  escl_args=(-r "$resolution" -o "$tmpdir")
  [[ "$source_opt" == "ADF Front" ]] && escl_args+=(-s)
  [[ "$mode" == "Gray" ]] && escl_args+=(-g)
  set +e
  "$escl_scan" "${escl_args[@]}"
  escl_rc=$?
  set -e
  if [[ $escl_rc -eq 1 ]]; then
    echo "scan2pdf: scan failed — run scan-diag for a checkup." >&2
    exit 1
  fi
else
  # In --batch mode scanimage scans until the feeder is empty, then always ends
  # with "Document feeder out of documents" and a nonzero status — that is the
  # normal terminator, not an error. Page count is the real success signal.
  set +e
  scanimage -d "$device" --source "$source_opt" --mode "$mode" \
    --resolution "$resolution" --format="$img_format" \
    ${scanopts[@]+"${scanopts[@]}"} \
    --batch="$tmpdir/page-%03d.$img_ext" --progress
  set -e
fi

shopt -s nullglob
pages=("$tmpdir"/page-*."$img_ext")
shopt -u nullglob

if [[ ${#pages[@]} -eq 0 ]]; then
  echo "scan2pdf: no pages scanned — is the ADF empty? Load a stack and retry." >&2
  echo "  If pages were loaded, run scan-diag for troubleshooting." >&2
  exit 2
fi

mkdir -p "$outdir"
timestamp=$(date +%Y%m%d-%H%M%S)
pdf="$outdir/$name-$timestamp.pdf"

# --imgsize pins the physical page size from the known scan resolution, so the
# PDF is correct even if the intermediate images carry no DPI metadata.
if ! img2pdf --imgsize "${resolution}dpix${resolution}dpi" --output "$pdf" "${pages[@]}"; then
  echo "scan2pdf: PDF assembly failed (img2pdf error above)." >&2
  if [[ $keep_pages -eq 0 ]]; then
    echo "  Re-run with --keep-pages to preserve the scanned page images." >&2
  fi
  exit 3
fi

if [[ $keep_pages -eq 1 ]]; then
  pagedir="$outdir/$name-$timestamp-pages"
  mkdir -p "$pagedir"
  mv "${pages[@]}" "$pagedir/"
fi

size=$(du -h "$pdf" | cut -f1 | tr -d ' ')
echo "Done: ${#pages[@]} page(s), $size"
echo "$pdf"
if [[ $keep_pages -eq 1 ]]; then
  echo "Intermediate page images kept in: $pagedir"
fi
if [[ $open_pdf -eq 1 ]]; then
  open "$pdf"
fi
