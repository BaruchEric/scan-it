#!/usr/bin/env bash
# checks-normalize — make every page of a check PDF uniform: cropped to the
# paper, deskewed, all pages landscape check-shaped.
#
# Renders each page at 300 dpi (honoring page rotation), trims the scanner
# background, deskews residual tilt, rotates portrait BACK pages (even page
# numbers) to landscape — bank-image convention: endorsement strip along the
# left edge — and rebuilds the PDF in place.
#
# Safe to re-run: already-landscape pages are never rotated again.
#
# Part of the ix500-scan project (~/Arik/dev/office/scan-it).
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: checks-normalize <checksYYYYMMDD.pdf> [more.pdf ...]

Run after checks-split (or after appending to a paydate PDF). Replaces each
PDF in place with uniform check-sized landscape pages: front upright, back
rotated to landscape like bank check images.
EOF
}

[[ $# -ge 1 ]] || { usage >&2; exit 64; }
if [[ "$1" == "-h" || "$1" == "--help" ]]; then usage; exit 0; fi

for tool in pdftoppm magick img2pdf; do
  command -v "$tool" >/dev/null 2>&1 || { echo "checks-normalize: '$tool' not found" >&2; exit 1; }
done

for pdf in "$@"; do
  [[ -f "$pdf" ]] || { echo "checks-normalize: no such file: $pdf" >&2; exit 66; }
  tmp=$(mktemp -d -t checks-normalize)
  # shellcheck disable=SC2064
  trap "rm -rf '$tmp'" EXIT

  pdftoppm -png -r 300 "$pdf" "$tmp/p"

  i=0
  fw=0; fh=0
  for f in "$tmp"/p-*.png; do
    i=$((i + 1))
    out=$(printf '%s/n-%03d.jpg' "$tmp" "$i")
    # Trim the gray scanner backing, straighten residual tilt, trim again.
    magick "$f" -fuzz 12% -trim +repage \
      -background white -deskew 40% \
      -fuzz 12% -trim +repage "$tmp/t.png"
    read -r w h < <(magick identify -format '%w %h\n' "$tmp/t.png")
    if (( i % 2 == 1 )); then
      # Front page: remember its size — the back is the same physical sheet.
      fw=$w; fh=$h
      magick "$tmp/t.png" -quality 85 "$out"
    else
      # Back page: portrait → landscape (bank-image convention).
      if (( h > w )); then
        magick "$tmp/t.png" -rotate 270 "$tmp/t2.png"
        mv "$tmp/t2.png" "$tmp/t.png"
        t=$w; w=$h; h=$t
      fi
      # Near-blank backs over-crop to just the printed area; restore them to
      # the front's size so every page stays check-sized and uniform.
      if (( fw > 0 )) && (( w * 10 < fw * 9 || h * 10 < fh * 9 )); then
        if (( h * 2 < fh )); then
          # Sliver = the horizontal endorsement strip; stand it up vertically
          # so it sits along the left edge like every other back.
          magick "$tmp/t.png" -rotate 270 "$tmp/t2.png"
          mv "$tmp/t2.png" "$tmp/t.png"
        fi
        magick "$tmp/t.png" -background white -gravity West \
          -extent "${fw}x${fh}" -quality 85 "$out"
      else
        magick "$tmp/t.png" -quality 85 "$out"
      fi
    fi
  done

  (( i > 0 )) || { echo "checks-normalize: no pages rendered from $pdf" >&2; exit 3; }

  img2pdf --imgsize 300dpix300dpi "$tmp"/n-*.jpg -o "$tmp/out.pdf"
  mv "$tmp/out.pdf" "$pdf"
  rm -rf "$tmp"
  trap - EXIT
  echo "$pdf: $i page(s) normalized"
done
